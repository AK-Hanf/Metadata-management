import json
import os

def txt_to_json(txt_file, json_file=None):
    # If no JSON output path is provided, save in the same folder with .json extension
    if json_file is None:
        json_file = os.path.splitext(txt_file)[0] + ".json"

    data = []

    # Read each line from TXT file
    with open(txt_file, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:  # skip empty lines
                data.append(line)

    # Write to JSON file
    with open(json_file, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

    print(f"✅ Converted '{txt_file}' → '{json_file}'")


